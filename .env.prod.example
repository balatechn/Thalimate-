# Copy this to .env.prod and fill in real values before running docker-compose.prod.yml

# ── SSL / Traefik ─────────────────────────────────────────────────────────────
ACME_EMAIL=your@email.com

# ── Hostnames (use sslip.io if no domain yet) ─────────────────────────────────
EVOLUTION_HOST=evo.187.127.134.246.sslip.io
N8N_HOST=n8n.187.127.134.246.sslip.io
# APP_HOST=app.187.127.134.246.sslip.io  # only needed for Option A

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://i6h4xkkql7ief09noki6w0b0.187.127.134.246.sslip.io  # Coolify URL

# ── Database (shared with Coolify stack) ─────────────────────────────────────
DATABASE_URL=postgresql://thalimate:thalimate@127.0.0.1:5434/thalimate?sslmode=disable
POSTGRES_HOST=127.0.0.1
POSTGRES_USER=thalimate
POSTGRES_PASSWORD=thalimate

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_KEY=replace-me-strong-key

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-me-strong-password

# ── Shared secret: app ↔ n8n (generate with: openssl rand -hex 32) ────────────
N8N_INTERNAL_SECRET=replace-me-openssl-rand-hex-32

# ── Telegram notifications (optional) ────────────────────────────────────────
TELEGRAM_CHAT_ID=
