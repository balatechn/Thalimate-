# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=ThaliMate
TZ=Asia/Kolkata

# --- Database ---
DATABASE_URL=postgresql://thalimate:thalimate@localhost:5432/thalimate?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=replace-with-32-byte-random-secret
JWT_EXPIRES_IN=7d
ADMIN_BOOTSTRAP_EMAIL=admin@thalimate.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!123

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=replace-me
EVOLUTION_INSTANCE=thalimate
EVOLUTION_WEBHOOK_SECRET=replace-with-hmac-secret

# --- Payments ---
PAYMENT_PROVIDER=razorpay   # razorpay | upi_qr
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
UPI_VPA=thalimate@upi
UPI_PAYEE_NAME=ThaliMate

# --- Storage (S3 compatible / local) ---
STORAGE_DRIVER=local        # local | s3
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=thalimate
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- n8n ---
N8N_WEBHOOK_BASE=http://localhost:5678/webhook

# --- Misc ---
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=60
